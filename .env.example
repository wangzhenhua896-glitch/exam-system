# AI Grading System - 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# =============================================================================
# 通义千问 (阿里云)
# =============================================================================
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-max
QWEN_ENABLED=true

# =============================================================================
# 智谱 GLM
# =============================================================================
GLM_API_KEY=your-glm-api-key
GLM_MODEL=glm-4
GLM_ENABLED=true

# =============================================================================
# MiniMax
# =============================================================================
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-group-id
MINIMAX_MODEL=abab6.5-chat
MINIMAX_ENABLED=true

# =============================================================================
# 百度文心一言 (可选)
# =============================================================================
ERNIE_API_KEY=your-ernie-api-key
ERNIE_SECRET_KEY=your-ernie-secret-key
ERNIE_MODEL=ernie-4.0
ERNIE_ENABLED=false

# =============================================================================
# 字节跳动豆包 (火山引擎 Coding Plan / 火山方舟)
# =============================================================================
# Coding Plan 专用配置
# DOUBAO_API_KEY 是你的 API Key (在方舟控制台获取)
# DOUBAO_MODEL 推荐使用 ark-code-latest，由控制台管理模型选择
# 也可以指定具体模型：doubao-seed-2.0-code, doubao-seed-2.0-pro, etc.
# DOUBAO_BASE_URL Coding Plan OpenAI 兼容接口专用
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL=ark-code-latest
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
DOUBAO_ENABLED=true

# =============================================================================
# 系统配置
# =============================================================================
DEFAULT_SAMPLE_COUNT=3
DEFAULT_STRATEGY=confidence_weighted
CONFIDENCE_LOW=0.6
CONFIDENCE_MEDIUM=0.7
CONFIDENCE_HIGH=0.8

# =============================================================================
# Web 服务
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
FLASK_DEBUG=true
